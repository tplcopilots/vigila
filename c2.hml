<!DOCTYPE html>
<html lang="en" class="h-full">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CallFlow — Contact Center</title>
    <meta name="csrf-token" content="{{ csrf_token() }}">
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600;9..40,700;9..40,900&family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        surface: { 50:'#fafaf9',100:'#f5f5f4',200:'#e7e5e4',300:'#d6d3d1',400:'#a8a29e',500:'#78716c',600:'#57534e',700:'#44403c',800:'#292524',900:'#1c1917',950:'#0f0e0d' },
                        accent: { 50:'#fffbeb',100:'#fef3c7',200:'#fde68a',300:'#fcd34d',400:'#fbbf24',500:'#f59e0b',600:'#d97706',700:'#b45309',800:'#92400e',900:'#78350f' },
                    },
                    fontFamily: {
                        display: ['Space Grotesk','sans-serif'],
                        body: ['DM Sans','sans-serif'],
                    }
                }
            }
        }
    </script>
    <style>
        :root{--bg:#0f0e0d;--fg:#fafaf9;--muted:#78716c;--accent:#f59e0b;--card:#1c1917;--border:#292524}
        *{box-sizing:border-box}
        body{font-family:'DM Sans',sans-serif;background:var(--bg);color:var(--fg);margin:0}
        .custom-scroll::-webkit-scrollbar{width:5px}
        .custom-scroll::-webkit-scrollbar-track{background:transparent}
        .custom-scroll::-webkit-scrollbar-thumb{background:var(--border);border-radius:10px}
        .custom-scroll::-webkit-scrollbar-thumb:hover{background:var(--muted)}
        .grain{position:fixed;inset:0;pointer-events:none;z-index:9999;opacity:.025;background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E")}
        .orb{position:fixed;border-radius:50%;filter:blur(90px);pointer-events:none;opacity:.06;z-index:0}
        .typing-dot{animation:tb 1.4s infinite ease-in-out}
        .typing-dot:nth-child(2){animation-delay:.2s}
        .typing-dot:nth-child(3){animation-delay:.4s}
        @keyframes tb{0%,60%,100%{transform:translateY(0);opacity:.4}30%{transform:translateY(-6px);opacity:1}}
        .pulse-ring{animation:pr 2s infinite}
        @keyframes pr{0%{box-shadow:0 0 0 0 rgba(16,185,129,.5)}70%{box-shadow:0 0 0 8px rgba(16,185,129,0)}100%{box-shadow:0 0 0 0 rgba(16,185,129,0)}}
        .msg-enter{animation:ms .3s cubic-bezier(.16,1,.3,1)}
        @keyframes ms{from{opacity:0;transform:translateY(14px) scale(.97)}to{opacity:1;transform:translateY(0) scale(1)}}
        .conv-item{transition:all .15s ease;cursor:pointer;border-left:3px solid transparent}
        .conv-item:hover{background:rgba(245,158,11,.05)}
        .conv-item.active{background:rgba(245,158,11,.1);border-left-color:var(--accent)!important}
        .quick-btn{transition:all .15s ease;border:1px solid var(--border);background:var(--card)}
        .quick-btn:hover{border-color:var(--accent);background:rgba(245,158,11,.08);transform:translateY(-1px)}
        .input-glow:focus-within{box-shadow:0 0 0 2px rgba(245,158,11,.25);border-color:var(--accent)!important}
        .toast-enter{animation:ti .35s cubic-bezier(.16,1,.3,1)}
        @keyframes ti{from{opacity:0;transform:translateX(100%) scale(.9)}to{opacity:1;transform:translateX(0) scale(1)}}
        .toast-exit{animation:to2 .25s ease forwards}
        @keyframes to2{to{opacity:0;transform:translateX(100%) scale(.9)}}
        .skeleton{animation:sh 1.8s infinite linear;background:linear-gradient(90deg,var(--card) 25%,#292524 50%,var(--card) 75%);background-size:200% 100%;border-radius:.75rem}
        @keyframes sh{0%{background-position:200% 0}100%{background-position:-200% 0}}
        .modal-overlay{backdrop-filter:blur(8px);background:rgba(0,0,0,.6)}
        .star-btn{transition:all .15s ease}.star-btn:hover{transform:scale(1.25)}.star-btn.active{color:var(--accent);transform:scale(1.15)}
        @media(max-width:1023px){.bridge-wrap:not(.expanded) .chat-main{display:none}.bridge-wrap:not(.expanded) .info-panel{display:none!important}.bridge-wrap.expanded .sidebar-panel{display:none}}
        @media(min-width:1024px){.back-to-list-btn{display:none!important}}
        @media(prefers-reduced-motion:reduce){*,*::before,*::after{animation-duration:.01ms!important;transition-duration:.01ms!important}}
        .d-none{display:none!important}
    </style>
</head>
<body class="h-full overflow-hidden font-body">
    <div class="grain"></div>
    <div class="orb" style="width:400px;height:400px;background:#f59e0b;top:-100px;left:-100px"></div>
    <div class="orb" style="width:300px;height:300px;background:#10b981;bottom:-80px;right:-80px"></div>

    <!-- Toast Container -->
    <div id="toastContainer" class="fixed top-4 right-4 z-50 flex flex-col gap-2" aria-live="polite"></div>

    <!-- Satisfaction Modal -->
    <div id="satisfactionModal" class="fixed inset-0 z-40 hidden items-center justify-center modal-overlay">
        <div class="bg-surface-900 border border-surface-800 rounded-2xl shadow-2xl w-full max-w-sm mx-4 p-6 text-center" role="dialog" aria-label="Rate Conversation">
            <div class="w-14 h-14 rounded-full bg-accent-500/10 flex items-center justify-center mx-auto mb-4"><i class="fas fa-star text-accent-400 text-xl"></i></div>
            <h3 class="font-display font-bold text-lg mb-2">Rate This Conversation</h3>
            <p class="text-surface-400 text-sm mb-5">How would you rate this interaction?</p>
            <div class="flex justify-center gap-3 mb-5" id="starRating">
                <button class="star-btn text-2xl text-surface-600" data-star="1" onclick="setRating(1)" aria-label="1 star"><i class="fas fa-star"></i></button>
                <button class="star-btn text-2xl text-surface-600" data-star="2" onclick="setRating(2)" aria-label="2 stars"><i class="fas fa-star"></i></button>
                <button class="star-btn text-2xl text-surface-600" data-star="3" onclick="setRating(3)" aria-label="3 stars"><i class="fas fa-star"></i></button>
                <button class="star-btn text-2xl text-surface-600" data-star="4" onclick="setRating(4)" aria-label="4 stars"><i class="fas fa-star"></i></button>
                <button class="star-btn text-2xl text-surface-600" data-star="5" onclick="setRating(5)" aria-label="5 stars"><i class="fas fa-star"></i></button>
            </div>
            <textarea id="ratingNote" rows="2" placeholder="Optional notes..." class="w-full bg-surface-800 border border-surface-700 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:border-accent-500 transition-colors placeholder:text-surface-600 resize-none mb-4"></textarea>
            <div class="flex gap-3">
                <button onclick="closeSatisfactionModal()" class="flex-1 px-4 py-2.5 rounded-xl border border-surface-700 text-sm font-medium hover:bg-surface-800 transition-colors">Skip</button>
                <button onclick="submitRating()" class="flex-1 px-4 py-2.5 rounded-xl bg-accent-500 text-surface-950 text-sm font-bold hover:bg-accent-400 transition-colors">Submit</button>
            </div>
        </div>
    </div>

    <!-- ===== MAIN LAYOUT ===== -->
    <div class="bridge-wrap h-full flex relative z-10">

        <!-- LEFT SIDEBAR -->
        <aside class="sidebar-panel w-80 min-w-[300px] bg-surface-950/80 border-r border-surface-800 flex flex-col h-full">
            <div class="p-4 border-b border-surface-800">
                <div class="flex items-center justify-between mb-4">
                    <div class="flex items-center gap-2.5">
                        <div class="w-9 h-9 rounded-xl bg-accent-500 flex items-center justify-center"><i class="fas fa-headset text-surface-950 text-sm"></i></div>
                        <div>
                            <h1 class="font-display font-bold text-sm leading-tight">CallFlow</h1>
                            <p class="text-[10px] text-surface-500 font-medium tracking-wider uppercase">Contact Center</p>
                        </div>
                    </div>
                    <button onclick="toggleSound()" id="soundBtn" class="w-8 h-8 rounded-lg flex items-center justify-center hover:bg-surface-800 transition-colors" aria-label="Toggle sound" title="Sound">
                        <i class="fas fa-volume-up text-surface-400 text-xs"></i>
                    </button>
                </div>
                <div class="flex items-center gap-2 bg-surface-900 rounded-xl px-3 py-2">
                    <div class="w-2.5 h-2.5 rounded-full bg-emerald-400 pulse-ring" id="agentStatusDot"></div>
                    <span class="text-xs font-medium text-emerald-400" id="agentStatusText">Online</span>
                    <div class="flex-1"></div>
                    <select id="agentStatusSelect" onchange="changeAgentStatus(this.value)" class="bg-transparent text-xs text-surface-400 focus:outline-none cursor-pointer appearance-none pr-4" style="background-image:url('data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 width=%2210%22 height=%226%22><path d=%22M0 0l5 6 5-6z%22 fill=%22%2378716c%22/></svg>');background-repeat:no-repeat;background-position:right center" aria-label="Status">
                        <option value="online" class="bg-surface-900">Online</option>
                        <option value="busy" class="bg-surface-900">Busy</option>
                        <option value="away" class="bg-surface-900">Away</option>
                    </select>
                </div>
            </div>
            <div class="p-3 border-b border-surface-800">
                <div class="relative">
                    <i class="fas fa-search absolute left-3 top-1/2 -translate-y-1/2 text-surface-500 text-xs"></i>
                    <input type="text" id="convSearch" placeholder="Search conversations..." class="w-full bg-surface-800/60 border border-surface-700/50 rounded-xl pl-9 pr-4 py-2 text-xs focus:outline-none focus:border-accent-500/50 transition-colors placeholder:text-surface-600" oninput="filterConversationsClient()" aria-label="Search">
                </div>
            </div>
            <div id="conversationList" class="flex-1 overflow-y-auto custom-scroll py-1" role="list">
                <div class="skeleton h-12 mx-3 mt-2"></div>
                <div class="skeleton h-12 mx-3 mt-2"></div>
                <div class="skeleton h-12 mx-3 mt-2"></div>
            </div>
            <div class="p-3 border-t border-surface-800">
                <div class="flex items-center justify-between">
                    <div class="flex items-center gap-1.5">
                        <div class="w-2 h-2 rounded-full bg-emerald-400 animate-pulse" id="sseDot"></div>
                        <span class="text-[10px] text-surface-500" id="sseLabel">SSE Connected</span>
                    </div>
                    <span class="text-[10px] text-surface-600 font-mono" id="sseStatus">streaming</span>
                </div>
            </div>
        </aside>

        <!-- CENTER: CHAT -->
        <main class="chat-main flex-1 flex flex-col h-full bg-surface-900/40">
            <header class="h-16 border-b border-surface-800 flex items-center justify-between px-5 bg-surface-950/60 backdrop-blur-sm flex-shrink-0">
                <div class="flex items-center gap-3">
                    <button id="backToListBtn" class="back-to-list-btn d-none w-8 h-8 rounded-lg flex items-center justify-center hover:bg-surface-800 transition-colors mr-1" aria-label="Back"><i class="fas fa-arrow-left text-surface-400 text-sm"></i></button>
                    <div id="chatAvatar" class="w-9 h-9 rounded-full bg-surface-800 flex items-center justify-center text-surface-400 font-bold text-sm">?</div>
                    <div>
                        <h2 id="conversationTitle" class="font-display font-semibold text-sm leading-tight">Select a conversation</h2>
                        <div class="flex items-center gap-1.5">
                            <div id="chatStatusDot" class="w-1.5 h-1.5 rounded-full bg-surface-600"></div>
                            <span id="chatStatus" class="text-[11px] text-surface-500">No active chat</span>
                        </div>
                    </div>
                </div>
                <div class="flex items-center gap-1.5">
                    <span id="chatTimer" class="text-[11px] text-surface-500 font-mono mr-2 d-none">00:00</span>
                    <button onclick="toggleInfoPanel()" class="w-8 h-8 rounded-lg flex items-center justify-center hover:bg-surface-800 transition-colors" title="Details" aria-label="Info"><i class="fas fa-user-circle text-surface-400 text-sm"></i></button>
                    <button onclick="openSatisfactionModal()" class="w-8 h-8 rounded-lg flex items-center justify-center hover:bg-surface-800 transition-colors" title="Rate" aria-label="Rate"><i class="fas fa-star text-surface-400 text-sm"></i></button>
                </div>
            </header>

            <div id="messageBox" class="flex-1 overflow-y-auto custom-scroll px-5 py-4" role="log" aria-label="Messages">
                <div id="emptyState" class="flex flex-col items-center justify-center h-full text-center">
                    <div class="w-20 h-20 rounded-2xl bg-surface-800/60 flex items-center justify-center mb-5"><i class="fas fa-comments text-surface-600 text-3xl"></i></div>
                    <h3 class="font-display font-semibold text-surface-300 mb-2">No Conversation Selected</h3>
                    <p class="text-sm text-surface-500 max-w-xs">Choose a conversation from the list to start viewing and sending messages.</p>
                </div>
            </div>

            <div id="typingIndicator" class="d-none px-5 pb-1">
                <div class="flex items-center gap-2 text-surface-500 text-xs">
                    <div class="flex gap-1">
                        <div class="typing-dot w-1.5 h-1.5 rounded-full bg-accent-400"></div>
                        <div class="typing-dot w-1.5 h-1.5 rounded-full bg-accent-400"></div>
                        <div class="typing-dot w-1.5 h-1.5 rounded-full bg-accent-400"></div>
                    </div>
                    <span id="typingText">Typing...</span>
                </div>
            </div>

            <div id="quickReplies" class="px-5 pb-2 d-none">
                <div class="flex gap-2 flex-wrap">
                    <button class="quick-btn px-3 py-1.5 rounded-full text-[11px] font-medium" onclick="sendQuickReply(this.textContent)">Hello, how can I help you?</button>
                    <button class="quick-btn px-3 py-1.5 rounded-full text-[11px] font-medium" onclick="sendQuickReply(this.textContent)">Could you provide more details?</button>
                    <button class="quick-btn px-3 py-1.5 rounded-full text-[11px] font-medium" onclick="sendQuickReply(this.textContent)">Please hold while I check that.</button>
                    <button class="quick-btn px-3 py-1.5 rounded-full text-[11px] font-medium" onclick="sendQuickReply(this.textContent)">Is there anything else I can help with?</button>
                    <button class="quick-btn px-3 py-1.5 rounded-full text-[11px] font-medium" onclick="sendQuickReply(this.textContent)">Thank you for contacting us!</button>
                </div>
            </div>

            <div class="p-4 border-t border-surface-800 bg-surface-950/60 backdrop-blur-sm flex-shrink-0">
                <form id="replyForm" class="flex items-end gap-2">
                    <button type="button" onclick="toggleEmoji()" class="w-9 h-9 rounded-xl flex items-center justify-center hover:bg-surface-800 transition-colors" aria-label="Emoji"><i class="fas fa-smile text-surface-400 text-sm"></i></button>
                    <div class="flex-1 input-glow border border-surface-700 rounded-xl bg-surface-800/50 transition-all">
                        <textarea id="replyInput" rows="1" placeholder="Type a message..." class="w-full bg-transparent px-4 py-2.5 text-sm focus:outline-none resize-none placeholder:text-surface-600 max-h-32" disabled aria-label="Message input"></textarea>
                    </div>
                    <button type="submit" id="replyBtn" class="w-9 h-9 rounded-xl bg-accent-500 hover:bg-accent-400 flex items-center justify-center transition-all hover:scale-105 active:scale-95 disabled:opacity-30 disabled:hover:scale-100" aria-label="Send" disabled>
                        <i class="fas fa-paper-plane text-surface-950 text-sm"></i>
                    </button>
                </form>
                <div id="emojiPicker" class="d-none mt-2 bg-surface-800 border border-surface-700 rounded-xl p-3 grid grid-cols-8 gap-1 max-h-40 overflow-y-auto custom-scroll"></div>
            </div>
        </main>

        <!-- RIGHT PANEL -->
        <aside id="infoPanel" class="info-panel w-72 min-w-[280px] bg-surface-950/80 border-l border-surface-800 flex-col h-full overflow-y-auto custom-scroll hidden lg:flex">
            <div id="infoPanelContent" class="flex flex-col h-full">
                <div class="flex flex-col items-center justify-center h-full text-center p-6">
                    <div class="w-14 h-14 rounded-2xl bg-surface-800/60 flex items-center justify-center mb-4"><i class="fas fa-info-circle text-surface-600 text-xl"></i></div>
                    <p class="text-sm text-surface-500">Select a conversation to view details</p>
                </div>
            </div>
        </aside>
    </div>

<script>
// ================================================================
// YOUR ORIGINAL BACKEND CONFIG — preserved exactly
// ================================================================
const urls = {
    conversations: "{{ route('web-chat-new.conversations') }}",
    history: "{{ route('web-chat-new.history') }}",
    stream: "{{ route('web-chat-new.stream') }}",
    reply: "{{ route('web-chat-new.reply') }}",
}

const csrfToken = document.querySelector('meta[name="csrf-token"]')?.getAttribute('content') || ''
const bridgeWrap = document.querySelector('.bridge-wrap')
const backBtn = document.getElementById('backToListBtn')
const conversationList = document.getElementById('conversationList')
const messageBox = document.getElementById('messageBox')
const title = document.getElementById('conversationTitle')
const replyForm = document.getElementById('replyForm')
const replyInput = document.getElementById('replyInput')
const replyBtn = document.getElementById('replyBtn')

let activeConversationId = ''
let loadingConversations = false
let loadingHistory = false
let eventSource = null
let lastMessageId = 0

// UI-only state
let soundEnabled = true
let currentRating = 0
let chatTimerSec = 0
let chatTimerRef = null
let allConvCache = []
let currentConvItem = null

// ================================================================
// YOUR ORIGINAL UTILITIES — preserved exactly
// ================================================================
function escapeHtml(value) {
    const div = document.createElement('div')
    div.textContent = value || ''
    return div.innerHTML
}

function formatTimestamp(value) {
    if (!value) return ''
    const date = new Date(value)
    if (Number.isNaN(date.getTime())) return value
    return date.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' })
}

function formatFullDate(value) {
    if (!value) return ''
    const date = new Date(value)
    if (Number.isNaN(date.getTime())) return value
    return date.toLocaleDateString([], { month: 'short', day: 'numeric', year: 'numeric' })
}

function showTypingIndicator(text = 'Typing...') {
    const indicator = document.getElementById('typingIndicator')
    const typingText = document.getElementById('typingText')
    if (!indicator) return
    if (typingText) typingText.textContent = text
    indicator.classList.remove('d-none')
}

function hideTypingIndicator(delay = 1200) {
    const indicator = document.getElementById('typingIndicator')
    if (!indicator) return
    window.clearTimeout(indicator.hideTimeout)
    indicator.hideTimeout = window.setTimeout(() => {
        indicator.classList.add('d-none')
    }, delay)
}

function autoResizeInput() {
    if (!replyInput) return
    replyInput.style.height = 'auto'
    replyInput.style.height = Math.min(replyInput.scrollHeight, 180) + 'px'
}

function handleReplyKeydown(event) {
    if (event.key === 'Enter' && !event.shiftKey) {
        event.preventDefault()
        replyForm.dispatchEvent(new Event('submit', { cancelable: true }))
    }
}

// ================================================================
// TOAST — replaces all alert() calls
// ================================================================
function showToast(message, type) {
    type = type || 'info'
    const container = document.getElementById('toastContainer')
    const icons = { success:'fa-check-circle text-emerald-400', error:'fa-exclamation-circle text-red-400', info:'fa-info-circle text-accent-400', warning:'fa-exclamation-triangle text-amber-400' }
    const borders = { success:'border-emerald-800/50', error:'border-red-800/50', info:'border-accent-800/50', warning:'border-amber-800/50' }
    const toast = document.createElement('div')
    toast.className = 'toast-enter flex items-center gap-2.5 px-4 py-3 rounded-xl bg-surface-900/95 border ' + (borders[type]||borders.info) + ' shadow-xl backdrop-blur-sm min-w-[260px]'
    toast.innerHTML = '<i class="fas ' + (icons[type]||icons.info) + ' text-sm flex-shrink-0"></i><span class="text-sm font-medium">' + escapeHtml(message) + '</span>'
    container.appendChild(toast)
    setTimeout(function() {
        toast.classList.remove('toast-enter')
        toast.classList.add('toast-exit')
        setTimeout(function() { toast.remove() }, 300)
    }, 3000)
}

// ================================================================
// AUDIO
// ================================================================
function playNotifSound() {
    if (!soundEnabled) return
    try {
        var ctx = new (window.AudioContext || window.webkitAudioContext)()
        var osc = ctx.createOscillator()
        var gain = ctx.createGain()
        osc.connect(gain); gain.connect(ctx.destination)
        osc.frequency.value = 880; osc.type = 'sine'
        gain.gain.setValueAtTime(0.06, ctx.currentTime)
        gain.gain.exponentialRampToValueAtTime(0.001, ctx.currentTime + 0.12)
        osc.start(ctx.currentTime); osc.stop(ctx.currentTime + 0.12)
    } catch(e) {}
}

function toggleSound() {
    soundEnabled = !soundEnabled
    document.getElementById('soundBtn').innerHTML = '<i class="fas fa-volume-' + (soundEnabled ? 'up' : 'mute') + ' text-surface-400 text-xs"></i>'
    showToast(soundEnabled ? 'Sound enabled' : 'Sound muted', 'info')
}

// ================================================================
// AGENT STATUS
// ================================================================
function changeAgentStatus(status) {
    var dot = document.getElementById('agentStatusDot')
    var text = document.getElementById('agentStatusText')
    var map = {
        online: { bg:'bg-emerald-400', tc:'text-emerald-400', label:'Online', pulse:true },
        busy: { bg:'bg-amber-400', tc:'text-amber-400', label:'Busy', pulse:false },
        away: { bg:'bg-surface-400', tc:'text-surface-400', label:'Away', pulse:false }
    }
    var s = map[status] || map.online
    dot.className = 'w-2.5 h-2.5 rounded-full ' + s.bg + (s.pulse ? ' pulse-ring' : '')
    text.className = 'text-xs font-medium ' + s.tc
    text.textContent = s.label
    showToast('Status changed to ' + s.label, 'info')
}

// ================================================================
// CHAT TIMER
// ================================================================
function startChatTimer() {
    chatTimerSec = 0
    var el = document.getElementById('chatTimer')
    el.classList.remove('d-none')
    if (chatTimerRef) clearInterval(chatTimerRef)
    chatTimerRef = setInterval(function() {
        chatTimerSec++
        var m = String(Math.floor(chatTimerSec / 60)).padStart(2, '0')
        var s = String(chatTimerSec % 60).padStart(2, '0')
        el.textContent = m + ':' + s
    }, 1000)
}

function stopChatTimer() {
    if (chatTimerRef) clearInterval(chatTimerRef)
    document.getElementById('chatTimer').classList.add('d-none')
}

// ================================================================
// EMOJI
// ================================================================
var emojis = ['😊','👍','❤️','😂','🎉','🔥','✅','❌','💡','⭐','📞','📧','💰','📦','🛒','🔧','⚡','🎯','📌','💬','👋','🙏','💪','🤝','👏','🆗','⏰','🔍','📎','📊','💼','🖥️']

function renderEmojiPicker() {
    document.getElementById('emojiPicker').innerHTML = emojis.map(function(e) {
        return '<button type="button" class="w-8 h-8 rounded-lg hover:bg-surface-700 flex items-center justify-center text-lg transition-colors" onclick="insertEmoji(\'' + e + '\')">' + e + '</button>'
    }).join('')
}

function toggleEmoji() { document.getElementById('emojiPicker').classList.toggle('d-none') }

function insertEmoji(emoji) {
    replyInput.value += emoji
    replyInput.focus()
    replyBtn.disabled = !replyInput.value.trim()
}

// ================================================================
// QUICK REPLIES
// ================================================================
function sendQuickReply(text) {
    replyInput.value = text
    replyBtn.disabled = false
    replyForm.dispatchEvent(new Event('submit', { cancelable: true }))
}

// ================================================================
// CLIENT-SIDE SEARCH
// ================================================================
function filterConversationsClient() {
    var q = document.getElementById('convSearch').value.toLowerCase()
    if (!allConvCache.length) return
    var filtered = allConvCache.filter(function(item) {
        var id = item.conversation_id || item.external_id || ''
        var preview = item.last_message || item.preview || ''
        return id.toLowerCase().indexOf(q) !== -1 || preview.toLowerCase().indexOf(q) !== -1 || (item.channel || '').toLowerCase().indexOf(q) !== -1
    })
    renderConvItems(filtered)
}

// ================================================================
// SATISFACTION MODAL
// ================================================================
function openSatisfactionModal() {
    if (!activeConversationId) { showToast('Select a conversation first', 'warning'); return }
    document.getElementById('satisfactionModal').classList.remove('hidden')
    document.getElementById('satisfactionModal').classList.add('flex')
    currentRating = 0
    document.querySelectorAll('#starRating .star-btn').forEach(function(b) { b.classList.remove('active'); b.style.color = '' })
    document.getElementById('ratingNote').value = ''
}
function closeSatisfactionModal() {
    document.getElementById('satisfactionModal').classList.add('hidden')
    document.getElementById('satisfactionModal').classList.remove('flex')
}
function setRating(star) {
    currentRating = star
    document.querySelectorAll('#starRating .star-btn').forEach(function(b) {
        var s = parseInt(b.dataset.star)
        b.classList.toggle('active', s <= star)
        b.style.color = s <= star ? 'var(--accent)' : ''
    })
}
function submitRating() {
    if (!currentRating) { showToast('Please select a rating', 'error'); return }
    closeSatisfactionModal()
    showToast('Rating submitted: ' + currentRating + '/5 stars', 'success')
}

// ================================================================
// INFO PANEL
// ================================================================
function toggleInfoPanel() {
    var p = document.getElementById('infoPanel')
    p.classList.toggle('hidden')
    p.classList.toggle('flex')
}

function renderInfoPanel(convItem, msgCount) {
    if (!convItem) return
    var id = convItem.conversation_id || convItem.external_id || '—'
    var channel = (convItem.channel || 'web').toLowerCase()
    var channelUp = channel.toUpperCase()
    var channelIcon = { web:'fa-globe', chat:'fa-comment-dots', phone:'fa-phone', email:'fa-envelope', whatsapp:'fa-whatsapp', telegram:'fa-telegram' }[channel] || 'fa-globe'
    var lastAt = convItem.last_message_at || convItem.updated_at || ''
    var preview = convItem.last_message || convItem.preview || ''

    document.getElementById('infoPanelContent').innerHTML =
        '<div class="p-5 border-b border-surface-800 text-center">' +
            '<div class="w-16 h-16 rounded-full bg-accent-500/15 flex items-center justify-center text-accent-400 font-display font-bold text-xl mx-auto mb-3">' + escapeHtml(id.charAt(0).toUpperCase()) + '</div>' +
            '<h3 class="font-display font-bold text-base break-all">' + escapeHtml(id) + '</h3>' +
            '<div class="flex justify-center gap-2 mt-3">' +
                '<span class="px-2.5 py-0.5 rounded-full bg-surface-800 text-surface-300 text-[10px] font-semibold uppercase tracking-wider flex items-center gap-1"><i class="fas ' + channelIcon + ' text-[8px]"></i>' + escapeHtml(channelUp) + '</span>' +
            '</div>' +
        '</div>' +
        '<div class="p-4 border-b border-surface-800">' +
            '<h4 class="text-[10px] uppercase tracking-widest text-surface-500 font-semibold mb-3">Details</h4>' +
            '<div class="space-y-2.5">' +
                '<div class="flex items-center justify-between"><span class="text-xs text-surface-400">ID</span><span class="text-xs font-mono font-medium text-accent-400">' + escapeHtml(id) + '</span></div>' +
                '<div class="flex items-center justify-between"><span class="text-xs text-surface-400">Channel</span><span class="text-xs font-medium capitalize">' + escapeHtml(channel) + '</span></div>' +
                '<div class="flex items-center justify-between"><span class="text-xs text-surface-400">Messages</span><span class="text-xs font-medium">' + msgCount + '</span></div>' +
                (lastAt ? '<div class="flex items-center justify-between"><span class="text-xs text-surface-400">Last Activity</span><span class="text-xs font-medium">' + escapeHtml(formatFullDate(lastAt)) + '</span></div>' : '') +
                (lastAt ? '<div class="flex items-center justify-between"><span class="text-xs text-surface-400">Time</span><span class="text-xs font-mono font-medium">' + escapeHtml(formatTimestamp(lastAt)) + '</span></div>' : '') +
            '</div>' +
        '</div>' +
        '<div class="p-4 border-b border-surface-800">' +
            '<h4 class="text-[10px] uppercase tracking-widest text-surface-500 font-semibold mb-2">Last Message</h4>' +
            '<p class="text-xs text-surface-300 leading-relaxed">' + escapeHtml(preview) + '</p>' +
        '</div>' +
        '<div class="p-4 border-b border-surface-800">' +
            '<h4 class="text-[10px] uppercase tracking-widest text-surface-500 font-semibold mb-3">Actions</h4>' +
            '<div class="space-y-2">' +
                '<button onclick="showToast(\'Notes saved\',\'success\')" class="w-full px-3 py-2 rounded-xl bg-surface-800 hover:bg-surface-700 text-xs font-medium transition-colors flex items-center gap-2"><i class="fas fa-sticky-note text-surface-400 text-[10px] w-4"></i> Add Note</button>' +
                '<button onclick="showToast(\'Conversation tagged\',\'success\')" class="w-full px-3 py-2 rounded-xl bg-surface-800 hover:bg-surface-700 text-xs font-medium transition-colors flex items-center gap-2"><i class="fas fa-tag text-surface-400 text-[10px] w-4"></i> Add Tag</button>' +
                '<button onclick="navigator.clipboard.writeText(\'' + escapeHtml(id).replace(/'/g, "\\'") + '\');showToast(\'ID copied\',\'success\')" class="w-full px-3 py-2 rounded-xl bg-surface-800 hover:bg-surface-700 text-xs font-medium transition-colors flex items-center gap-2"><i class="fas fa-copy text-surface-400 text-[10px] w-4"></i> Copy ID</button>' +
            '</div>' +
        '</div>' +
        '<div class="p-4 mt-auto border-t border-surface-800">' +
            '<button onclick="openSatisfactionModal()" class="w-full px-3 py-2.5 rounded-xl bg-accent-500/10 hover:bg-accent-500/20 text-accent-400 text-xs font-semibold transition-colors flex items-center justify-center gap-1.5"><i class="fas fa-star text-[10px]"></i> Rate Conversation</button>' +
        '</div>'
}

// ================================================================
// RENDER: Conversation list items (enhanced)
// ================================================================
function renderConvItems(list) {
    if (!list.length) {
        conversationList.innerHTML = '<div class="flex flex-col items-center justify-center h-32 text-center px-4"><i class="fas fa-inbox text-surface-700 text-2xl mb-2"></i><p class="text-xs text-surface-500">No conversations found</p></div>'
        return
    }
    conversationList.innerHTML = list.map(function(item) {
        var id = item.conversation_id || item.external_id || ''
        var preview = item.last_message || item.preview || 'No messages yet'
        var when = item.last_message_at || item.updated_at || ''
        var channel = (item.channel || 'web').toLowerCase()
        var channelIcon = { web:'fa-globe', chat:'fa-comment-dots', phone:'fa-phone', email:'fa-envelope', whatsapp:'fa-whatsapp', telegram:'fa-telegram' }[channel] || 'fa-globe'
        var isActive = id === activeConversationId
        return '<div class="conv-item ' + (isActive ? 'active' : '') + ' px-3 py-3" data-id="' + escapeHtml(id) + '" role="listitem" tabindex="0">' +
            '<div class="flex items-start gap-2.5">' +
                '<div class="w-10 h-10 rounded-full bg-surface-800 flex items-center justify-center text-xs font-bold text-surface-300 flex-shrink-0">' + escapeHtml(id.charAt(0).toUpperCase()) + '</div>' +
                '<div class="flex-1 min-w-0">' +
                    '<div class="flex items-center justify-between mb-0.5">' +
                        '<span class="text-sm font-semibold truncate">' + escapeHtml(id) + '</span>' +
                        '<span class="text-[10px] text-surface-500 flex-shrink-0 ml-2">' + escapeHtml(formatTimestamp(when)) + '</span>' +
                    '</div>' +
                    '<div class="flex items-center gap-1.5 mb-1">' +
                        '<i class="fas ' + channelIcon + ' text-[9px] text-surface-600"></i>' +
                        '<span class="text-[10px] text-surface-500 uppercase tracking-wider">' + escapeHtml(channel) + '</span>' +
                    '</div>' +
                    '<p class="text-xs text-surface-400 truncate leading-relaxed">' + escapeHtml(preview) + '</p>' +
                '</div>' +
            '</div>' +
        '</div>'
    }).join('')
}

// ================================================================
// RENDER: Messages (enhanced)
// ================================================================
function renderMessages(msgs) {
    if (!msgs.length) {
        messageBox.innerHTML = '<div class="flex flex-col items-center justify-center h-full text-center"><i class="fas fa-comment-slash text-surface-700 text-3xl mb-3"></i><p class="text-sm text-surface-500">No messages yet</p></div>'
        return
    }
    messageBox.innerHTML = msgs.map(function(msg) {
        var role = (msg.role || 'user').toLowerCase()
        var text = msg.text || msg.message || ''
        var when = msg.created_at || ''

        if (role === 'system') {
            return '<div class="flex justify-center my-3 msg-enter"><div class="px-3 py-1 rounded-full bg-surface-800/60 text-[10px] text-surface-500 flex items-center gap-1.5"><i class="fas fa-info-circle text-[8px]"></i> ' + escapeHtml(text) + '</div></div>'
        }

        var isAdmin = role === 'admin'
        var isBot = role === 'bot'
        var alignRight = role === 'user'
        var bubble, meta

        if (isAdmin) {
            bubble = 'bg-emerald-900/40 border border-emerald-800/30 text-surface-100 rounded-2xl rounded-bl-md'
            meta = '<i class="fas fa-headset text-[8px] text-emerald-500 mr-0.5"></i>Agent'
        } else if (isBot) {
            bubble = 'bg-violet-900/30 border border-violet-800/20 text-surface-100 rounded-2xl rounded-bl-md'
            meta = '<i class="fas fa-robot text-[8px] text-violet-400 mr-0.5"></i>Bot'
        } else {
            bubble = 'bg-surface-800 border border-surface-700 text-surface-100 rounded-2xl rounded-br-md'
            meta = '<i class="fas fa-user text-[8px] text-surface-500 mr-0.5"></i>User'
        }

        return '<div class="flex ' + (alignRight ? 'justify-end' : 'justify-start') + ' mb-2 msg-enter">' +
            '<div class="max-w-[75%]">' +
                '<div class="' + bubble + ' px-4 py-2.5"><p class="text-sm leading-relaxed whitespace-pre-wrap">' + escapeHtml(text) + '</p></div>' +
                '<div class="flex items-center gap-1.5 mt-1 ' + (alignRight ? 'justify-end' : '') + '">' +
                    '<span class="text-[10px] text-surface-600">' + meta + '</span>' +
                    (when ? '<span class="text-[10px] text-surface-600">· ' + escapeHtml(formatTimestamp(when)) + '</span>' : '') +
                    (isAdmin ? '<i class="fas fa-check-double text-[9px] text-emerald-400"></i>' : '') +
                '</div>' +
            '</div>' +
        '</div>'
    }).join('')
}

// ================================================================
// CORE: loadConversations — your logic, enhanced rendering
// ================================================================
async function loadConversations() {
    if (loadingConversations) return
    loadingConversations = true

    try {
        var res = await fetch(urls.conversations)
        var payload = await res.json()
        var list = Array.isArray(payload.conversations) ? payload.conversations : []
        allConvCache = list

        if (!list.length) {
            conversationList.innerHTML = '<div class="flex flex-col items-center justify-center h-32 text-center px-4"><i class="fas fa-inbox text-surface-700 text-2xl mb-2"></i><p class="text-xs text-surface-500">No conversations yet</p></div>'
            return
        }

        renderConvItems(list)
    } catch (error) {
        conversationList.innerHTML = '<div class="flex flex-col items-center justify-center h-32 text-center px-4"><i class="fas fa-exclamation-triangle text-red-500/60 text-2xl mb-2"></i><p class="text-xs text-red-400">Failed to load conversations</p><button onclick="loadConversations()" class="mt-2 text-[10px] text-accent-400 hover:underline">Retry</button></div>'
    } finally {
        loadingConversations = false
    }
}

// ================================================================
// CORE: loadHistory — your logic, enhanced rendering
// ================================================================
async function loadHistory(conversationId, forceScrollBottom) {
    if (!conversationId) return
    if (loadingHistory) return
    loadingHistory = true

    activeConversationId = conversationId
    title.textContent = 'Conversation: ' + conversationId
    replyInput.disabled = false
    replyBtn.disabled = false
    autoResizeInput()
    expandChatWindow()
    startChatTimer()

    // Update chat header
    document.getElementById('chatAvatar').textContent = (conversationId || '?').charAt(0).toUpperCase()
    document.getElementById('chatAvatar').className = 'w-9 h-9 rounded-full bg-accent-500/15 flex items-center justify-center text-accent-400 font-bold text-sm'
    document.getElementById('chatStatusDot').className = 'w-1.5 h-1.5 rounded-full bg-emerald-400'
    document.getElementById('chatStatus').textContent = 'Active'
    document.getElementById('chatStatus').className = 'text-[11px] text-emerald-400'
    document.getElementById('quickReplies').classList.remove('d-none')

    var isNearBottom = messageBox.scrollHeight - messageBox.scrollTop - messageBox.clientHeight < 120

    try {
        var res = await fetch(urls.history + '?conversation_id=' + encodeURIComponent(conversationId))
        var payload = await res.json()
        var msgs = Array.isArray(payload.messages) ? payload.messages : []

        if (!msgs.length) {
            messageBox.innerHTML = '<div class="flex flex-col items-center justify-center h-full text-center"><i class="fas fa-comment-slash text-surface-700 text-3xl mb-3"></i><p class="text-sm text-surface-500">No messages yet</p></div>'
        } else {
            lastMessageId = msgs.reduce(function(maxId, msg) {
                var value = Number(msg.id)
                return Number.isFinite(value) ? Math.max(maxId, value) : maxId
            }, lastMessageId)

            renderMessages(msgs)
        }

        if (forceScrollBottom || isNearBottom) {
            messageBox.scrollTop = messageBox.scrollHeight
        }

        // Update info panel
        var convItem = allConvCache.find(function(c) {
            return (c.conversation_id || c.external_id) === conversationId
        })
        currentConvItem = convItem || null
        renderInfoPanel(convItem || { conversation_id: conversationId }, msgs.length)

        await loadConversations()
    } catch (error) {
        messageBox.innerHTML = '<div class="flex flex-col items-center justify-center h-full text-center"><i class="fas fa-exclamation-triangle text-red-500/60 text-3xl mb-3"></i><p class="text-sm text-red-400">Failed to load messages</p><button onclick="loadHistory(\'' + escapeHtml(conversationId).replace(/'/g, "\\'") + '\',true)" class="mt-2 text-xs text-accent-400 hover:underline">Retry</button></div>'
    } finally {
        loadingHistory = false
    }
}

// ================================================================
// EVENT: Conversation click
// ================================================================
conversationList.addEventListener('click', async function(event) {
    var item = event.target.closest('.conv-item')
    if (!item) return
    await loadHistory(item.dataset.id, true)
})

// Keyboard support for conv items
conversationList.addEventListener('keydown', function(event) {
    if (event.key === 'Enter') {
        var item = event.target.closest('.conv-item')
        if (item) loadHistory(item.dataset.id, true)
    }
})

// ================================================================
// EVENT: Back button
// ================================================================
backBtn.addEventListener('click', collapseChatWindow)

// ================================================================
// EVENT: Reply form submit — your logic, toast replaces alert
// ================================================================
replyForm.addEventListener('submit', async function(event) {
    event.preventDefault()

    var message = replyInput.value.trim()
    if (!activeConversationId || !message) return

    replyBtn.disabled = true

    try {
        var res = await fetch(urls.reply, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'X-CSRF-TOKEN': csrfToken,
            },
            body: JSON.stringify({
                conversation_id: activeConversationId,
                message: message,
            }),
        })

        var payload = await res.json()
        if (!res.ok || payload.status === 'error') {
            throw new Error(payload.message || 'Failed to send reply')
        }

        replyInput.value = ''
        autoResizeInput()
        await loadHistory(activeConversationId, true)
        replyInput.focus()
    } catch (error) {
        showToast(error.message || 'Unable to send reply', 'error')
    } finally {
        replyBtn.disabled = false
    }
})

// ================================================================
// INPUT EVENTS — your original handlers
// ================================================================
if (replyInput) {
    replyInput.addEventListener('input', function() {
        autoResizeInput()
        replyBtn.disabled = !replyInput.value.trim()
        if (replyInput.value.trim()) {
            showTypingIndicator('Drafting reply...')
            hideTypingIndicator(900)
        }
    })
    replyInput.addEventListener('keydown', handleReplyKeydown)
}

// ================================================================
// EXPAND / COLLAPSE — your original logic
// ================================================================
function expandChatWindow() {
    if (bridgeWrap) bridgeWrap.classList.add('expanded')
    if (backBtn) backBtn.classList.remove('d-none')
}

function collapseChatWindow() {
    if (bridgeWrap) bridgeWrap.classList.remove('expanded')
    if (backBtn) backBtn.classList.add('d-none')
    stopChatTimer()
    document.getElementById('quickReplies').classList.add('d-none')
}

// ================================================================
// CORE: SSE Stream — your logic, enhanced status indicator
// ================================================================
function startLiveStream() {
    if (eventSource) eventSource.close()

    document.getElementById('sseDot').className = 'w-2 h-2 rounded-full bg-emerald-400 animate-pulse'
    document.getElementById('sseLabel').textContent = 'SSE Connected'
    document.getElementById('sseStatus').textContent = 'streaming'

    eventSource = new EventSource(urls.stream + '?last_id=' + encodeURIComponent(lastMessageId))

    eventSource.addEventListener('message', async function(event) {
        try {
            var payload = JSON.parse(event.data)
            var messageId = Number(payload && payload.id)

            if (Number.isFinite(messageId)) {
                lastMessageId = Math.max(lastMessageId, messageId)
            }

            await loadConversations()

            if (activeConversationId && payload && payload.conversation_id === activeConversationId) {
                var role = (payload.role || 'user').toLowerCase()
                if (role === 'admin' || role === 'bot') {
                    showTypingIndicator('New message...')
                    hideTypingIndicator(900)
                    playNotifSound()
                } else {
                    playNotifSound()
                }
                await loadHistory(activeConversationId)
            } else if (payload && payload.conversation_id !== activeConversationId) {
                // New message in a different conversation
                playNotifSound()
            }
        } catch (error) {
            // Ignore malformed stream payloads
        }
    })

    eventSource.onerror = function() {
        document.getElementById('sseDot').className = 'w-2 h-2 rounded-full bg-amber-400 animate-pulse'
        document.getElementById('sseLabel').textContent = 'Reconnecting...'
        document.getElementById('sseStatus').textContent = 'retrying'

        if (eventSource) eventSource.close()
        window.setTimeout(function() {
            startLiveStream()
        }, 1200)
    }
}

// ================================================================
// CLOSE MODALS ON BACKDROP / ESCAPE
// ================================================================
document.getElementById('satisfactionModal').addEventListener('click', function(e) {
    if (e.target === this) closeSatisfactionModal()
})
document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') {
        closeSatisfactionModal()
        document.getElementById('emojiPicker').classList.add('d-none')
    }
})
document.addEventListener('click', function(e) {
    var picker = document.getElementById('emojiPicker')
    var btn = e.target.closest('[aria-label="Emoji"]')
    if (!picker.contains(e.target) && !btn) picker.classList.add('d-none')
})

// ================================================================
// BOOT
// ================================================================
renderEmojiPicker()
loadConversations()
startLiveStream()
</script>
</body>
</html>
